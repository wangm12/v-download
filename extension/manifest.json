{
  "manifest_version": 3,
  "name": "V-Download",
  "version": "1.1.0",
  "description": "Download videos and detect media streams on any website",
  "permissions": [
    "cookies",
    "activeTab",
    "tabs",
    "alarms",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["content-douyin-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["content-douyin.js"],
      "css": ["content-douyin.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-video-overlay.js"],
      "css": ["content-video-overlay.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content-douyin-bridge.js"],
      "matches": ["*://*.douyin.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16-gray.png",
      "48": "icons/icon48-gray.png"
    },
    "default_title": "V-Download",
    "default_popup": "popup.html"
  }
}
